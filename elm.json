{
    "type": "package",
    "name": "elm-cardano/sha2",
    "summary": "Fast elm/bytes based sha256 and sha512",
    "license": "BSD-3-Clause",
    "version": "1.0.0",
    "exposed-modules": [
        "SHA224",
        "SHA256",
        "SHA384",
        "SHA512"
    ],
    "elm-version": "0.19.1 <= v < 0.20.0",
    "dependencies": {
        "elm/bytes": "1.0.8 <= v < 2.0.0",
        "elm/core": "1.0.5 <= v < 2.0.0",
        "elm-cardano/base64": "1.0.1 <= v < 2.0.0",
        "elm-cardano/x-bytes": "1.1.0 <= v < 2.0.0"
    },
    "test-dependencies": {
        "elm-explorations/test": "2.2.1 <= v < 3.0.0"
    }
}
